---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import TablatureView from '../../components/TablatureView.astro';
import BridgeDiagram from '../../components/BridgeDiagram.astro';
import TimelineStrip from '../../components/TimelineStrip.astro';
import Player from '../../components/Player';
import tuningsRaw from '../../data/tunings.yaml';

export async function getStaticPaths() {
  const pieces = await getCollection('pieces');
  return pieces.map((piece) => ({
    params: { slug: piece.id },
    props: { piece },
  }));
}

const { piece } = Astro.props;
const { title, difficulty, tuning, tempo, tags, layers } = piece.data;
const tuningData = (tuningsRaw as any)[tuning]?.strings ?? {};
---
<Base title={title}>
  <a href="/">← Back to pieces</a>
  <h1>{title}</h1>
  <p>
    <small>{difficulty} · {tempo} BPM · {tags.join(', ')}</small>
  </p>

  <BridgeDiagram tuning={tuning} />

  <Player
    client:only="react"
    layers={layers}
    tuning={tuningData}
    tempo={tempo}
  />

  <TimelineStrip layers={layers} tuning={tuning} />

  {layers.map((layer, i) => (
    <div class="layer-tab" data-layer={i} style={i > 0 ? 'display:none' : ''}>
      <TablatureView steps={layer.steps} tuning={tuning} />
    </div>
  ))}

  <button class="outline" onclick="window.print()">Print tablature</button>

  <style is:global>
    @media print {
      #player, astro-island, .bridge-diagram, .timeline-strip,
      nav, a[href="/"], button.outline { display: none !important; }
    }
  </style>
</Base>

---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import TablatureView from '../../components/TablatureView.astro';
import BridgeDiagram from '../../components/BridgeDiagram.astro';
import Lookahead from '../../components/Lookahead.astro';
import Player from '../../components/Player';
import { getTuning } from '../../lib/tuning';

export async function getStaticPaths() {
  const pieces = await getCollection('pieces');
  return pieces.map((piece) => ({
    params: { slug: piece.id },
    props: { piece },
  }));
}

const { piece } = Astro.props;
const { title, tuning, tags, arrangements } = piece.data;
const tuningData = getTuning(tuning).strings;
---
<Base title={title} showNotation>
  <hgroup>
    <h1>
      {title}
      {arrangements.length > 1 && (
        <select id="arrangement-select" class="arrangement-select">
          {arrangements.map((arr, i) => (
            <option value={i}>{arr.name}</option>
          ))}
        </select>
      )}
      <small class="piece-meta">{tags.join(', ')}</small>
    </h1>
  </hgroup>

  <div class="play-area">
    <BridgeDiagram tuning={tuning} />
    <Lookahead arrangements={arrangements} tuning={tuning} />
  </div>

  <Player
    client:only="react"
    arrangements={arrangements}
    tuning={tuningData}
  />

  <details>
    <summary>Show tablature</summary>
    {arrangements.map((arr, i) => (
      <div class="arrangement-tab" data-arrangement={i} style={i > 0 ? 'display:none' : ''}>
        <TablatureView steps={arr.steps} tuning={tuning} />
      </div>
    ))}
    <button class="outline" onclick="window.print()">Print tablature</button>
  </details>

  <style>
    .piece-meta {
      font-weight: normal;
      font-size: 0.5em;
      opacity: 0.7;
    }
    .arrangement-select {
      display: inline-block;
      width: auto;
      margin-left: 0.5rem;
      vertical-align: middle;
      font-size: 0.875rem;
      font-weight: normal;
    }
    .play-area {
      display: flex;
      position: relative;
      justify-content: center;
      align-items: center;
    }
    @media (max-width: 480px) {
      h1 { font-size: 1.25rem; display: flex; align-items: center; justify-content: space-between; }
      details { display: none; }
      select { font-size: 0.75rem; padding: 0.25rem 0.5rem; }
      .piece-meta { display: none; }
      #player button { padding: 0.25rem 0.5rem; font-size: 0.875rem; }
      #player label { font-size: 0.75rem; }
      #player { gap: 0.5rem; margin: 0.5rem 0; }
      .keyboard-hint { display: none; }
    }
  </style>
  <style is:global>
    .lookahead { position: absolute; right: 0; }
    @media print {
      #player, astro-island, .bridge-diagram, .lookahead, .play-area,
      nav, a[href="/"], button.outline, #arrangement-select, summary { display: none !important; }
      details { display: block !important; }
      details > * { display: block !important; }
    }
  </style>
</Base>

<script>
  const sel = document.getElementById('arrangement-select') as HTMLSelectElement | null;
  if (sel) {
    sel.addEventListener('change', () => {
      const idx = Number(sel.value);
      document.querySelectorAll('.arrangement-tab').forEach((tab, i) => {
        (tab as HTMLElement).style.display = i === idx ? '' : 'none';
      });
      document.dispatchEvent(new CustomEvent('player-arrangement', { detail: { index: idx } }));
    });
  }
</script>

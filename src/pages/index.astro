---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const pieces = await getCollection('pieces');
const sorted = pieces.sort((a, b) => {
  const order = { beginner: 0, intermediate: 1, advanced: 2 };
  return order[a.data.difficulty] - order[b.data.difficulty];
});
---
<Base title="Pieces">
  <h1>Pieces</h1>
  {sorted.map((piece) => (
    <article>
      <a href={`/pieces/${piece.id}/`}><strong>{piece.data.title}</strong></a>
      <small>{piece.data.difficulty} · {piece.data.tags.join(', ')}</small>
    </article>
  ))}
</Base>

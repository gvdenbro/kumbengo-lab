---
import { getStepStrings, type Step } from '../lib/piece';
interface Props { steps: Step[]; tuning: string; }
const { steps, tuning } = Astro.props;
---
<table class="tablature" data-tuning={tuning}>
  <thead>
    <tr>
      <th>#</th>
      <th>Duration</th>
      <th>Strings</th>
    </tr>
  </thead>
  <tbody>
    {steps.map((step, i) => (
      <tr>
        <td>{i + 1}</td>
        <td>{step.d}</td>
        <td class="string-cell" data-strings={JSON.stringify(getStepStrings(step))}>{getStepStrings(step).join(', ') || '—'}</td>
      </tr>
    ))}
  </tbody>
</table>

<script>
  import { getStringLabel } from '../lib/labels';

  document.addEventListener('notation-change', ((e: CustomEvent) => {
    document.querySelectorAll('.tablature').forEach(table => {
      const tuningId = (table as HTMLElement).dataset.tuning || 'silaba';
      table.querySelectorAll('.string-cell').forEach(cell => {
        const strings: string[] = JSON.parse((cell as HTMLElement).dataset.strings || '[]');
        (cell as HTMLElement).textContent = strings.length
          ? strings.map(s => getStringLabel(s, e.detail, tuningId)).join(', ')
          : '—';
      });
    });
  }) as EventListener);
</script>

<style>
  .tablature { font-size: 0.8rem; }
  .tablature td, .tablature th { padding: 0.25rem 0.5rem; }
  @media (max-width: 480px) { .tablature { font-size: 0.7rem; } }
</style>

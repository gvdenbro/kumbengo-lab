---
import { getStepStrings, type Step } from '../lib/piece';
interface Props {
  steps: Step[];
  tuning: string;
}
const { steps, tuning } = Astro.props;
---
<div class="tablature" data-tuning={tuning}>
  <table>
    <thead>
      <tr>
        <th>Duration</th>
        <th>Left</th>
        <th>Right</th>
      </tr>
    </thead>
    <tbody>
      {steps.map((step) => {
        const strings = getStepStrings(step);
        const left = strings.filter(s => s.startsWith('L'));
        const right = strings.filter(s => s.startsWith('R'));
        return (
          <tr>
            <td>{step.d}</td>
            <td class="note-cell" data-strings={JSON.stringify(left)}>{left.join(', ') || '—'}</td>
            <td class="note-cell" data-strings={JSON.stringify(right)}>{right.join(', ') || '—'}</td>
          </tr>
        );
      })}
    </tbody>
  </table>
</div>

<style>
  .tablature table {
    width: 100%;
    border-collapse: collapse;
    font-variant-numeric: tabular-nums;
  }
  .tablature th, .tablature td {
    padding: 0.25rem 0.5rem;
    border-bottom: 1px solid var(--pico-muted-border-color);
    text-align: center;
  }
  .tablature th { font-size: 0.75rem; color: var(--pico-muted-color); }
  @media print {
    .tablature { break-inside: avoid; }
  }
</style>

<script>
  import { getStringLabel } from '../lib/labels';

  document.addEventListener('notation-change', ((e: CustomEvent) => {
    const mode = e.detail;
    document.querySelectorAll('.tablature').forEach((tab) => {
      const tuning = (tab as HTMLElement).dataset.tuning!;
      tab.querySelectorAll('.note-cell').forEach((cell) => {
        const strings: string[] = JSON.parse((cell as HTMLElement).dataset.strings || '[]');
        (cell as HTMLElement).textContent = strings.length
          ? strings.map(s => getStringLabel(s, mode, tuning)).join(', ')
          : '—';
      });
    });
  }) as EventListener);
</script>

---
interface Step { t: number; string?: string; strings?: string[]; }
interface Layer { name: string; difficulty: string; steps: Step[]; }
interface Props { layers: Layer[]; tuning: string; }
const { layers, tuning } = Astro.props;

function stepStrings(step: Step): string[] {
  return step.strings ?? (step.string ? [step.string] : []);
}
---
<div class="timeline-strip" data-tuning={tuning} role="region" aria-label="Timeline">
  {layers.map((layer, li) => (
    <div class="timeline-track" data-layer-track={li} data-active={li === 0 ? 'true' : 'false'} style={li > 0 ? 'display:none' : ''}>
      {layer.steps.map((step, i) => (
        <div class="timeline-step" data-index={i} data-strings={JSON.stringify(stepStrings(step))}>
          <span class="step-beat">{step.t}</span>
          <span class="step-strings">{stepStrings(step).join(', ')}</span>
        </div>
      ))}
    </div>
  ))}
</div>

<style>
  .timeline-strip {
    overflow-x: auto;
    padding: 0.5rem 0;
    margin: 1rem auto;
    max-width: 100%;
    -webkit-overflow-scrolling: touch;
  }
  .timeline-track {
    display: flex;
    gap: 0.25rem;
    width: max-content;
    margin: 0 auto;
  }
  .timeline-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.25rem 0.5rem;
    border: 1px solid #e5e5e5;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    min-width: 3rem;
    transition: background 0.15s, opacity 0.15s;
  }
  .timeline-step.current {
    background: #2563eb;
    color: white;
    border-color: #2563eb;
  }
  .timeline-step.past { opacity: 0.4; }
  .step-beat { font-size: 0.625rem; color: #888; }
  .current .step-beat { color: rgba(255,255,255,0.7); }
  @media print { .timeline-strip { display: none; } }
</style>

<script>
  import tuningsRaw from '../data/tunings.yaml';
  const tunings: Record<string, { strings: Record<string, { note: string }> }> = tuningsRaw as any;

  function timelineLabel(stringId: string, mode: string, tuningId: string): string {
    if (mode === 'note') return tunings[tuningId]?.strings[stringId]?.note ?? stringId;
    if (mode === 'distance') {
      const side = stringId[0];
      const num = parseInt(stringId.slice(1), 10);
      const total = side === 'L' ? 11 : 10;
      const mid = Math.ceil(total / 2);
      return num <= mid ? `${side}⇧${num}` : `${side}⇩${total - num + 1}`;
    }
    return stringId;
  }

  document.addEventListener('notation-change', ((e: CustomEvent) => {
    const tuningId = (document.querySelector('.timeline-strip') as HTMLElement)?.dataset.tuning || 'silaba';
    document.querySelectorAll('.timeline-step').forEach(step => {
      const strings: string[] = JSON.parse((step as HTMLElement).dataset.strings || '[]');
      const label = step.querySelector('.step-strings') as HTMLElement;
      if (label) label.textContent = strings.map(s => timelineLabel(s, e.detail, tuningId)).join(', ');
    });
  }) as EventListener);

  // Switch visible track when layer changes
  document.addEventListener('player-layer', ((e: CustomEvent) => {
    document.querySelectorAll('.timeline-track').forEach((track, i) => {
      const active = i === e.detail.index;
      (track as HTMLElement).style.display = active ? '' : 'none';
      (track as HTMLElement).dataset.active = String(active);
    });
  }) as EventListener);

  // Highlight current step in the active track
  document.addEventListener('player-step', ((e: CustomEvent) => {
    const idx = e.detail.index;
    const active = document.querySelector('.timeline-track[data-active="true"]');
    if (!active) return;
    const steps = active.querySelectorAll('.timeline-step');
    steps.forEach((step, i) => {
      step.classList.toggle('current', i === idx);
      step.classList.toggle('past', i < idx);
    });
    const current = steps[idx] as HTMLElement;
    current?.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
  }) as EventListener);
</script>

---
import { getStepStrings, type Step } from '../lib/piece';
interface Arrangement { name: string; difficulty: string; steps: Step[]; }
interface Props { arrangements: Arrangement[]; tuning: string; }
const { arrangements, tuning } = Astro.props;
---
<div class="timeline-strip" data-tuning={tuning} role="region" aria-label="Timeline">
  {arrangements.map((arr, ai) => (
    <div class="timeline-track" data-arrangement-track={ai} data-active={ai === 0 ? 'true' : 'false'} style={ai > 0 ? 'display:none' : ''}>
      {arr.steps.map((step, i) => (
        <div class="timeline-step" data-index={i} data-strings={JSON.stringify(getStepStrings(step))}>
          <span class="step-beat">{step.t}</span>
          <span class="step-strings">{getStepStrings(step).join(', ')}</span>
        </div>
      ))}
    </div>
  ))}
</div>

<style>
  .timeline-strip {
    overflow-x: auto;
    padding: 0.5rem 0;
    margin: 1rem auto;
    max-width: 100%;
    -webkit-overflow-scrolling: touch;
  }
  .timeline-track {
    display: flex;
    gap: 0.25rem;
    width: max-content;
    margin: 0 auto;
  }
  .timeline-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.25rem 0.5rem;
    border: 1px solid #e5e5e5;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    min-width: 3rem;
    transition: background 0.15s, opacity 0.15s;
  }
  .timeline-step.current {
    background: var(--pico-primary-background);
    color: var(--pico-primary-inverse);
    border-color: var(--pico-primary-border);
  }
  .timeline-step.past { opacity: 0.4; }
  .step-beat { font-size: 0.625rem; color: #888; }
  .current .step-beat { color: var(--pico-primary-inverse); opacity: 0.7; }
  @media print { .timeline-strip { display: none; } }
</style>

<script>
  import { getStringLabel } from '../lib/labels';

  document.addEventListener('notation-change', ((e: CustomEvent) => {
    const tuningId = (document.querySelector('.timeline-strip') as HTMLElement)?.dataset.tuning || 'silaba';
    document.querySelectorAll('.timeline-step').forEach(step => {
      const strings: string[] = JSON.parse((step as HTMLElement).dataset.strings || '[]');
      const label = step.querySelector('.step-strings') as HTMLElement;
      if (label) label.textContent = strings.map(s => getStringLabel(s, e.detail, tuningId)).join(', ');
    });
  }) as EventListener);

  document.addEventListener('player-arrangement', ((e: CustomEvent) => {
    document.querySelectorAll('.timeline-track').forEach((track, i) => {
      const active = i === e.detail.index;
      (track as HTMLElement).style.display = active ? '' : 'none';
      (track as HTMLElement).dataset.active = String(active);
    });
  }) as EventListener);

  document.addEventListener('player-step', ((e: CustomEvent) => {
    const idx = e.detail.index;
    const active = document.querySelector('.timeline-track[data-active="true"]');
    if (!active) return;
    const steps = active.querySelectorAll('.timeline-step');
    steps.forEach((step, i) => {
      step.classList.toggle('current', i === idx);
      step.classList.toggle('past', i < idx);
    });
    const current = steps[idx] as HTMLElement;
    current?.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
  }) as EventListener);
</script>

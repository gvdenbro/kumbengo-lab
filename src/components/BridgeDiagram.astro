---
interface Props { tuning: string; }
const { tuning } = Astro.props;
---
<div class="bridge-diagram" data-tuning={tuning} aria-label="Kora bridge">
  <div class="bridge-side left">
    {Array.from({length: 11}, (_, i) => (
      <div class="string-dot" data-string={`L${11 - i}`}>
        <span class="string-label">{`L${11 - i}`}</span>
      </div>
    ))}
  </div>
  <div class="bridge-center"></div>
  <div class="bridge-side right">
    {Array.from({length: 10}, (_, i) => (
      <div class="string-dot" data-string={`R${10 - i}`}>
        <span class="string-label">{`R${10 - i}`}</span>
      </div>
    ))}
  </div>
  <span id="bridge-live" class="sr-only" aria-live="polite"></span>
</div>

<style>
  .sr-only {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }
  .bridge-diagram {
    display: flex;
    justify-content: center;
    gap: 2rem;
    padding: 1rem;
  }
  .bridge-side { display: flex; flex-direction: column; gap: 0.25rem; }
  .bridge-side.right { margin-top: calc(1 * (2rem + 0.25rem)); }
  .bridge-center { width: 2px; background: #ccc; }
  .string-dot {
    width: 2rem; height: 2rem;
    border-radius: 50%;
    border: 2px solid #ccc;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.625rem;
  }
  .string-dot.active {
    background: var(--pico-primary-background);
    border-color: var(--pico-primary-border);
    color: var(--pico-primary-inverse);
  }
  .string-dot.pluck {
    animation: pluck 0.15s;
  }
  @keyframes pluck {
    0%   { transform: scale(1); }
    50%  { transform: scale(1.35); }
    100% { transform: scale(1); }
  }
  @media print { .bridge-diagram { display: none; } }
  @media (max-width: 480px) {
    .bridge-diagram { gap: 1rem; padding: 0.25rem; }
    .bridge-side { gap: 0.125rem; }
    .bridge-side.right { margin-top: calc(1.25rem + 0.125rem); }
    .string-dot { width: 1.25rem; height: 1.25rem; font-size: 0.5rem; border-width: 1px; }
  }
</style>

<script>
  import { getStringLabel } from '../lib/labels';

  document.addEventListener('notation-change', ((e: CustomEvent) => {
    const diagram = document.querySelector('.bridge-diagram') as HTMLElement;
    const tuningId = diagram?.dataset.tuning || 'silaba';
    document.querySelectorAll('.string-dot').forEach(dot => {
      const id = (dot as HTMLElement).dataset.string!;
      const label = dot.querySelector('.string-label') as HTMLElement;
      if (label) label.textContent = getStringLabel(id, e.detail, tuningId);
    });
  }) as EventListener);

  document.addEventListener('player-step', ((e: CustomEvent) => {
    document.querySelectorAll('.string-dot').forEach(dot => dot.classList.remove('active'));
    const strings: string[] = e.detail.strings;
    strings.forEach(s => {
      const dot = document.querySelector(`.string-dot[data-string="${s}"]`);
      if (!dot) return;
      dot.classList.add('active');
      dot.classList.remove('pluck');
      void (dot as HTMLElement).offsetWidth;
      dot.classList.add('pluck');
    });
    const live = document.getElementById('bridge-live');
    if (live) live.textContent = strings.join(', ');
  }) as EventListener);
</script>

---
interface Props { title: string; }
const { title } = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — Kumbengo Lab</title>
  <style is:global>
    @import "@picocss/pico/css/pico.amber.min.css";
  </style>
</head>
<body>
  <main class="container">
    <header>
      <nav>
        <ul><li><a href="/"><strong>Kumbengo Lab</strong></a></li></ul>
      </nav>
      <p><small>Learn the kora, one piece at a time</small></p>
    </header>
    <slot />
  </main>
</body>
</html>

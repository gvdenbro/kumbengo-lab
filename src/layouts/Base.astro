---
interface Props { title: string; showNotation?: boolean; }
const { title, showNotation = false } = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — Kumbengo Lab</title>
  <style is:global>
    @import "@picocss/pico/css/pico.amber.min.css";
    @media (max-width: 480px) {
      #notation-select { font-size: 0.75rem; padding: 0.25rem 0.5rem !important; background-image: none !important; }
      .container { padding: 0.5rem; }
      nav { padding: 0; }
    }
  </style>
</head>
<body>
  <main class="container">
    <header>
      <nav>
        <ul><li><a href="/"><strong>Kumbengo Lab</strong></a></li></ul>
        <ul>
          <li><a href="/">Pieces</a></li>
          <li><a href="/transcribe">Transcribe</a></li>
          {showNotation && (
            <li>
              <select id="notation-select" aria-label="Notation style" style="font-size:0.875rem;width:auto;">
                <option value="position">String (L1, R2)</option>
                <option value="note">Note (C4, F3)</option>
                <option value="distance">Near/Far (⇧⇩)</option>
              </select>
            </li>
          )}
        </ul>
      </nav>
    </header>
    <slot />
  </main>
</body>
<script>
  const sel = document.getElementById('notation-select') as HTMLSelectElement | null;
  if (sel) {
    const saved = localStorage.getItem('notation-mode') || 'position';
    sel.value = saved;
    document.dispatchEvent(new CustomEvent('notation-change', { detail: saved }));
    sel.addEventListener('change', () => {
      localStorage.setItem('notation-mode', sel.value);
      document.dispatchEvent(new CustomEvent('notation-change', { detail: sel.value }));
    });
  }
</script>
</html>

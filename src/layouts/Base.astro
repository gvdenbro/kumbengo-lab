---
interface Props { title: string; description?: string; showNotation?: boolean; }
const { title, description = 'Learn the kora, one piece at a time. Browse pieces, view tablature, and play back interactively.', showNotation = false } = Astro.props;
const pageTitle = `${title} — Kumbengo Lab`;
---
<!doctype html>
<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/png" href="/kora.png" />
  <title>{pageTitle}</title>
  <style is:global>
    @import "@picocss/pico/css/pico.amber.min.css";
    @media (max-width: 480px) {
      #notation-select { font-size: 0.75rem; padding: 0.25rem 0.5rem !important; background-image: none !important; }
      .container { padding: 0.5rem; }
      nav { padding: 0; }
    }
  </style>
</head>
<body>
  <main class="container">
    <header>
      <nav>
        <ul><li><a href="/"><strong>Kumbengo Lab</strong></a></li></ul>
        <ul>
          {showNotation && (
            <li>
              <select id="notation-select" aria-label="Notation style" style="font-size:0.875rem;width:auto;">
                <option value="position">String (L1, R2)</option>
                <option value="note">Note (C4, F3)</option>
                <option value="distance">Near/Far (⇧⇩)</option>
              </select>
            </li>
          )}
        </ul>
      </nav>
    </header>
    <slot />
  </main>
  <footer class="container" style="margin-top:2rem;text-align:center;">
    <small>
      <a href="https://github.com/gvdenbro/kumbengo-lab" target="_blank" rel="noopener">GitHub</a> ·
      <a href="/credits">Credits</a> ·
      AGPL-3.0
    </small>
  </footer>
</body>
<script>
  const sel = document.getElementById('notation-select') as HTMLSelectElement | null;
  if (sel) {
    const saved = localStorage.getItem('notation-mode') || 'position';
    sel.value = saved;
    document.dispatchEvent(new CustomEvent('notation-change', { detail: saved }));
    sel.addEventListener('change', () => {
      localStorage.setItem('notation-mode', sel.value);
      document.dispatchEvent(new CustomEvent('notation-change', { detail: sel.value }));
    });
  }
</script>
</html>
